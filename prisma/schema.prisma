generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Models ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  adAccounts    AdAccount[]
  draftCampaigns DraftCampaign[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Ad Platform Models ──────────────────────────────────────

enum Platform {
  META
  GOOGLE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
  ENDED
  ERROR
}

enum DraftStatus {
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

model AdAccount {
  id                String   @id @default(cuid())
  userId            String
  platform          Platform
  platformAccountId String
  accountName       String
  currency          String   @default("EUR")
  timezone          String   @default("Europe/Lisbon")
  isActive          Boolean  @default(true)
  campaigns         Campaign[]
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([platform, platformAccountId])
}

model Campaign {
  id                  String         @id @default(cuid())
  adAccountId         String
  platform            Platform
  platformCampaignId  String?
  name                String
  status              CampaignStatus @default(DRAFT)
  objective           String
  dailyBudget         Float?
  lifetimeBudget      Float?
  currency            String         @default("EUR")
  startDate           DateTime?
  endDate             DateTime?
  platformData        Json?
  isDraft             Boolean        @default(false)
  metrics             CampaignMetrics[]
  adAccount           AdAccount      @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  syncedAt            DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([platform, platformCampaignId])
}

model CampaignMetrics {
  id              String   @id @default(cuid())
  campaignId      String
  date            DateTime
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  cpc             Float    @default(0)
  cpm             Float    @default(0)
  spend           Float    @default(0)
  conversions     Int      @default(0)
  conversionValue Float    @default(0)
  roas            Float    @default(0)
  reach           Int?     // Meta only
  qualityScore    Float?   // Google only
  platformData    Json?
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  syncedAt        DateTime @default(now())

  @@unique([campaignId, date])
}

model DraftCampaign {
  id              String      @id @default(cuid())
  userId          String
  platform        Platform
  name            String
  objective       String
  targetingConfig Json?
  budgetConfig    Json?
  creativeConfig  Json?
  status          DraftStatus @default(PENDING_REVIEW)
  reviewNotes     String?     @db.Text
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
